{
  "name": "extension",
  "displayName": "VisaAgency Extension",
  "version": "0.0.1",
  "description": "A basic Plasmo extension.",
  "author": "Plasmo Corp. <foss@plasmo.com>",
  "contributors": [
    "louisgv"
  ],
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint: ok'"
  },
  "dependencies": {
    "@david-agency/shared": "workspace:*",
    "@plasmohq/storage": "^1.15.0",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "prettier": "3.2.4",
    "typescript": "5.3.3"
  },
  "manifest": {
    "key": "",
    "host_permissions": [
      "https://*/*"
    ],
    "externally_connectable": {
      "matches": [
        "http://localhost/*",
        "https://david-agency.vercel.app/*",
        "https://*.vercel.app/*"
      ]
    }
  }
}
